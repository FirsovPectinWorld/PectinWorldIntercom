<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F7">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/loginBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PectinWorld Intercom"
                android:textAlignment="center"
                android:textColor="#1D1D1F"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Введите ваш персональный пароль для идентификации в системе"
                android:textAlignment="center"
                android:textColor="#86868B"
                android:textSize="14sp"
                android:layout_marginBottom="32dp"/>

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Пароль доступа"
                android:inputType="textPassword"
                android:background="@android:drawable/editbox_background"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Войти в систему"
                android:textSize="16sp"
                android:backgroundTint="#0071E3"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/intercomBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/welcomeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Привет, Пользователь!"
                android:textAlignment="center"
                android:textColor="#1D1D1F"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Внутренняя связь Pectin World"
                android:textAlignment="center"
                android:textColor="#34C759"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="40dp"/>

            <TextView
                android:id="@+id/txtContactOne"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👉 Свайп вправо: Вызвать Галину"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />
            <SeekBar
                android:id="@+id/seekContactOne"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:max="100"
                android:progress="0"
                android:splitTrack="false"
                android:progressDrawable="@drawable/slider_track"
                android:thumb="@drawable/slider_thumb"
                android:thumbOffset="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/txtContactTwo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👉 Свайп вправо: Вызвать Сергея"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />
            <SeekBar
                android:id="@+id/seekContactTwo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:max="100"
                android:progress="0"
                android:splitTrack="false"
                android:progressDrawable="@drawable/slider_track"
                android:thumb="@drawable/slider_thumb"
                android:thumbOffset="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnGeneralCall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📢 Общий сбор (Неактивна)"
                android:enabled="false"
                android:alpha="0.5"
                android:layout_marginTop="12dp" />
        </LinearLayout>

    </RelativeLayout>
</ScrollView>